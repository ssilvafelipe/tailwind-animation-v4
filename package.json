{
  "name": "@ssilva.felipe/tailwind-animation-v4",
  "description": "Plugin animation for tailwind 4",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./theme.css": "./dist/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:css": "postcss ./test/index.css -o ./test/output.css --env production",
    "debug:css": "postcss ./test/index.css -o ./test/output.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "generate:css": "tsx src/scripts/generate-css.ts"
  },
  "peerDependencies": {
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@tailwindcss/node": "^4.3.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.3",
    "postcss": "^8.5.15",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.3.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fss/tailwind-animation-v4": "link:"
  }
}